  "description": "VIN Decoding Reference \u2014 maps VIN characters to vehicle make, model, year, and manufacturing country. The WMI (World Manufacturer Identifier) is characters 1-3 of the VIN. Character 10 encodes the model year.",
  "vinStructure": {
    "description": "A VIN (Vehicle Identification Number) is a 17-character code that identifies every vehicle uniquely.",
    "positions": {
      "1-3": "WMI \u2014 World Manufacturer Identifier (country + manufacturer + vehicle type)",
      "4-8": "VDS \u2014 Vehicle Descriptor Section (model, body style, engine, etc.)",
      "9": "Check digit \u2014 mathematical verification of VIN validity",
      "10": "Model year code",
      "11": "Plant code \u2014 where the vehicle was assembled",
      "12-17": "VIS \u2014 Vehicle Identifier Section (serial number of the vehicle)"
    }
  },
